# MyCompanion API Configurations
GROQ_API_KEY=gsk_your_groq_key_here
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Feature Control Flags (true/false)
ENABLE_VISION=true
ENABLE_STT=true
ENABLE_TTS=true
ENABLE_VTS=true
ENABLE_MOVEMENT=true

# Idle Threshold Timers (seconds)
MOVEMENT_IDLE_THRESHOLD=120.0
BOREDOM_IDLE_THRESHOLD=300.0
DREAM_IDLE_THRESHOLD=600.0
DREAM_CYCLE_DURATION=600.0

# Screen Capture & VLM Configs
VISION_CAPTURE_INTERVAL=30.0
VISION_JPEG_QUALITY=60
VISION_MAX_WIDTH=1280
VISION_MAX_HEIGHT=720

# Audio Input/Output Configurations
STT_SAMPLE_RATE=16000
STT_CHUNK_DURATION=5.0
STT_SILENCE_THRESHOLD=0.01
TTS_VOICE=vi-VN-HoaiMyNeural
TTS_PLAYER=mpv

# Rate Limits (Groq Free Limits)
DAILY_TOKEN_QUOTA=28000
TOKENS_PER_MINUTE=5500
REQUEST_MINUTE=25
MAX_TOKENS_PER_RESPONSE=512

# Custom Local Paths
DATA_DIR=~/.mycompanion
DB_PATH=~/.mycompanion/companion.db
LOG_PATH=~/.mycompanion/companion.log

# UI Window Style Configurations
UI_WIDTH=320
UI_HEIGHT=400
UI_INITIAL_X=100
UI_INITIAL_Y=100
UI_OPACITY=0.92

# Persona Properties
COMPANION_NAME=Hana
USER_NAME=Chủ nhân
LANGUAGE=vi
DEBUG=false
